<Window x:Class="ClipboardApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ClipboardApp.Converters"
        xmlns:models="clr-namespace:ClipboardApp.Models"
        Title="剪切板"
        Width="430"
        Height="620"
        MinWidth="360"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <converters:EntryTypeVisibilityConverter x:Key="TextVisibility" Match="Text" />
        <converters:EntryTypeVisibilityConverter x:Key="ImageVisibility" Match="Image" />

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F2F6FA" />
            <Setter Property="Background" Value="#243141" />
            <Setter Property="BorderBrush" Value="#3A4A5D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#33475C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#415A72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="#55758EA8"
            BorderThickness="1"
            Background="#AA121821">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="False"
                       Margin="0,0,0,14"
                       MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="剪切板"
                               Foreground="#FFFFFF"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CountText"
                               Foreground="#AFC0D0"
                               FontSize="12"
                               Margin="1,2,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource IconButton}"
                        Content="×"
                        FontSize="18"
                        Width="38"
                        Padding="0"
                        Click="HideButton_Click"
                        ToolTip="隐藏" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Background="#1F2A38"
                        BorderBrush="#405267"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F7FAFC"
                             CaretBrush="#FFFFFF"
                             FontSize="14"
                             Padding="12,9"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="搜索文字内容" />
                </Border>
                <TextBlock Text="搜索文字"
                           IsHitTestVisible="False"
                           Foreground="#7F92A6"
                           Margin="13,0,0,0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        Content="清空"
                        Margin="10,0,0,0"
                        Click="ClearButton_Click" />
            </Grid>

            <ListBox x:Name="EntryList"
                     Grid.Row="2"
                     ItemsSource="{Binding}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionMode="Single"
                     PreviewMouseLeftButtonUp="EntryList_PreviewMouseLeftButtonUp"
                     PreviewMouseRightButtonUp="EntryList_PreviewMouseRightButtonUp"
                     MouseMove="EntryList_MouseMove">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="0,0,0,10" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ClipboardEntry}">
                        <Border x:Name="ItemRoot"
                                Background="#B01D2734"
                                BorderBrush="#35485B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <DockPanel LastChildFill="True" Margin="0,0,0,8">
                                        <Border DockPanel.Dock="Left"
                                                Background="#314257"
                                                CornerRadius="5"
                                                Padding="7,3"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding TypeLabel}"
                                                       Foreground="#D8E8F7"
                                                       FontSize="11" />
                                        </Border>
                                        <TextBlock Text="{Binding TimeLabel}"
                                                   Foreground="#90A4B8"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>

                                    <TextBlock Text="{Binding PreviewText}"
                                               Foreground="#F3F7FB"
                                               FontSize="14"
                                               LineHeight="20"
                                               TextWrapping="Wrap"
                                               MaxHeight="96"
                                               Visibility="{Binding Type, Converter={StaticResource TextVisibility}}" />

                                    <Border Width="150"
                                            Height="110"
                                            HorizontalAlignment="Left"
                                            Background="#101820"
                                            CornerRadius="7"
                                            ClipToBounds="True"
                                            Visibility="{Binding Type, Converter={StaticResource ImageVisibility}}">
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform" />
                                    </Border>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="删除"
                                        Background="#7A2634"
                                        BorderBrush="#A94658"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Click="DeleteEntryButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDeleteArmed}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#D02A3848" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#5D7B96" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <DockPanel Grid.Row="3" Margin="0,10,0,0">
                <CheckBox x:Name="StartupCheckBox"
                          Content="开机自启"
                          Foreground="#D8E8F7"
                          VerticalAlignment="Center"
                          Checked="StartupCheckBox_Changed"
                          Unchecked="StartupCheckBox_Changed" />
                <TextBlock DockPanel.Dock="Right"
                           Text="左键复制，右键删除"
                           Foreground="#8195A9"
                           FontSize="12"
                           HorizontalAlignment="Right" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
